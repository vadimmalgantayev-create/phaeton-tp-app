// Prisma schema for the Phaeton TP ETL loader.
//
// Scope note: this schema was authored from scratch for this task because no
// project resource / git remote was available to reach the actual PHA-68
// (MVP app) codebase or its Prisma schema — see README.md "Известные
// ограничения" for details. It models only the entities the ETL loader
// itself needs to read/write (ТЗ section 5, minus Order/GPS/Photo-audit/Note
// which belong to the app, not the loader). If/when the PHA-68 repo becomes
// reachable, these models should be reconciled with (not duplicated next to)
// its existing ones.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Region {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  managers  Manager[]
  discounts Discount[]
  users     User[]

  @@map("regions")
}

model Manager {
  id        Int         @id @default(autoincrement())
  name      String
  region    Region      @relation(fields: [regionId], references: [id])
  regionId  Int
  clients   Client[]
  plans     Plan[]
  acbPlans  AcbPlan[]
  salesFacts SalesFact[]
  missingInvoices MissingInvoice[]
  user      User?
  routeVisits RouteVisit[]

  @@unique([name, regionId])
  @@map("managers")
}

// Логин/роль (ТЗ 6.1). ТП привязан к конкретному Manager (данные каталога/
// дашборда скоупятся по managerId); Руководитель привязан к Region (см.
// PHA-82, scope.js) -- данные кабинета руководителя скоупятся по regionId;
// Администратор — без привязки, видит всё.
model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  role         String   // "TP" | "RUKOVODITEL" | "ADMIN"
  isActive     Boolean  @default(true)
  manager      Manager? @relation(fields: [managerId], references: [id])
  managerId    Int?     @unique
  region       Region?  @relation(fields: [regionId], references: [id])
  regionId     Int?     @unique
  createdAt    DateTime @default(now())
  notes        Note[]
  orders       Order[]

  @@map("users")
}

model Note {
  id        Int      @id @default(autoincrement())
  client    Client   @relation(fields: [clientId], references: [id])
  clientId  Int
  author    User     @relation(fields: [authorId], references: [id])
  authorId  Int
  text      String
  createdAt DateTime @default(now())

  @@map("notes")
}

model Order {
  id          Int         @id @default(autoincrement())
  client      Client      @relation(fields: [clientId], references: [id])
  clientId    Int
  createdBy   User        @relation(fields: [createdById], references: [id])
  createdById Int
  status      String      @default("draft") // "draft" | "exported"
  createdAt   DateTime    @default(now())
  exportedAt  DateTime?
  lines       OrderLine[]

  @@map("orders")
}

model OrderLine {
  id              Int     @id @default(autoincrement())
  order           Order   @relation(fields: [orderId], references: [id])
  orderId         Int
  product         Product @relation(fields: [productId], references: [id])
  productId       Int
  quantity        Float
  discountPercent Float
  clientPrice     Float
  supplierPrice   Float

  @@map("order_lines")
}

// ТЗ 6.9: маршрут на день + гео-чек-ин у клиента.
//
// PHA-81: расстояние ТП-клиент на момент отметки. ⚑ Допущение: ТЗ просило
// отдельную сущность Visit(managerId, clientId, visitedAt, lat, lng, hasGeo,
// distanceM, clientLat, clientLng) — здесь вместо неё расширена уже
// существующая RouteVisit (ровно тот же набор полей + day для маршрута на
// день), а не заведена вторая параллельная таблица с той же ролью. Причина:
// RouteVisit уже хранит факт отметки (managerId+clientId+day, upsert —
// одна отметка в день на клиента) и используется в /route и здесь; отдельная
// Visit-таблица дублировала бы её без нового смысла. Если заказчику нужна
// история НЕСКОЛЬКИХ отметок в день по одному клиенту — это отдельное
// решение (снять @@unique), выходящее за рамки этой задачи, и его стоит
// явно согласовать, а не подставлять молча.
model RouteVisit {
  id         Int       @id @default(autoincrement())
  manager    Manager   @relation(fields: [managerId], references: [id])
  managerId  Int
  client     Client    @relation(fields: [clientId], references: [id])
  clientId   Int
  day        DateTime  // start-of-day (UTC), one planned visit per client per day
  visitedAt  DateTime?
  latitude   Float?    // ТП: координаты в момент отметки
  longitude  Float?
  hasGeo     Boolean   @default(false) // false = отметка без гео (запрет/недоступно), но факт+время сохранены
  distanceM  Float?    // haversine(ТП, клиент) в метрах; null если нет гео ТП или координат клиента
  clientLat  Float?    // координаты клиента на момент отметки (снимок, чтобы отчёт не "плыл" при переезде адреса)
  clientLng  Float?

  @@unique([managerId, clientId, day])
  @@map("route_visits")
}

model Client {
  id              Int              @id @default(autoincrement())
  code            String?          @unique // "Код клиента" from addresses file; not every source file carries it
  name            String
  manager         Manager?         @relation(fields: [managerId], references: [id])
  managerId       Int?
  route           String?
  addresses       ClientAddress[]
  discounts       Discount[]
  debt            Debt?
  salesFacts      SalesFact[]
  missingInvoices MissingInvoice[]
  notes           Note[]
  orders          Order[]
  routeVisits     RouteVisit[]

  // Intentionally no unique(name, managerId): the addresses file (the only
  // source with a real client code) has real cases of two different codes
  // sharing one display name under the same manager, so name is not a safe
  // uniqueness key — only `code` is. Other source files that lack a code
  // (discounts/debt/sales/missing-invoices) resolve clients by name via an
  // in-memory cache in load.js, which can't tell such same-named clients
  // apart either — a documented limitation, not enforced at the DB level.
  @@map("clients")
}

model ClientAddress {
  id              Int     @id @default(autoincrement())
  client          Client  @relation(fields: [clientId], references: [id])
  clientId        Int
  city            String
  deliveryAddress String
  isPrimary       Boolean @default(false)
  deliveryType    String?
  phone           String?
  latitude        Float?
  longitude       Float?

  @@map("client_addresses")
}

model Product {
  id                   Int      @id @default(autoincrement())
  article              String
  article1c            String?
  brand                String
  name                 String
  tnved                String?
  packQty              Int?
  priceGross           Float? // "Цена без скидки"
  generalDiscountPct   Float? // "Общая скидка"
  priceNet             Float? // "Цена" (после общей скидки прайса)
  application          String?
  isServiceRow         Boolean  @default(false) // no price -> служебная строка, скрыть из каталога
  stocks               Stock[]
  orderLines           OrderLine[]

  @@unique([article, brand])
  @@map("products")
}

model Stock {
  id         Int     @id @default(autoincrement())
  product    Product @relation(fields: [productId], references: [id])
  productId  Int
  warehouse  String // "Алматы СКЛАД" | "Астана СКЛАД" | "Кар Сити СКЛАД"
  quantity   Float

  @@unique([productId, warehouse])
  @@map("stocks")
}

model Discount {
  id         Int       @id @default(autoincrement())
  region     Region?   @relation(fields: [regionId], references: [id])
  regionId   Int?
  client     Client?   @relation(fields: [clientId], references: [id])
  clientId   Int?
  brand      String
  percent    Float
  validUntil DateTime?

  @@map("discounts")
}

model Debt {
  id                 Int       @id @default(autoincrement())
  client             Client    @relation(fields: [clientId], references: [id])
  clientId           Int       @unique
  totalDebt          Float
  limitAmount        Float?
  nearestPaymentDate DateTime?
  bucketUnder3d      Float     @default(0)
  bucket3to7d        Float     @default(0)
  bucket7to14d       Float     @default(0)
  bucket14to30d      Float     @default(0)
  bucket30to60d      Float     @default(0)
  bucket60to90d      Float     @default(0)
  bucket90to180d     Float     @default(0)
  bucket180dTo1y     Float     @default(0)
  bucket1to2y        Float     @default(0)
  bucket2to3y        Float     @default(0)
  bucketOver3y       Float     @default(0)
  isOverdue          Boolean   @default(false)

  @@map("debts")
}

model SalesFact {
  id          Int      @id @default(autoincrement())
  manager     Manager  @relation(fields: [managerId], references: [id])
  managerId   Int
  client      Client   @relation(fields: [clientId], references: [id])
  clientId    Int
  brand       String
  month       DateTime // first day of month, e.g. 2026-01-01
  quantity    Float    @default(0)
  volumeL     Float    @default(0)
  revenueEur  Float    @default(0)

  @@unique([managerId, clientId, brand, month])
  @@map("sales_facts")
}

model Plan {
  id           Int     @id @default(autoincrement())
  manager      Manager @relation(fields: [managerId], references: [id])
  managerId    Int
  taskType     String // "BRAND_GROUP" | "TOTAL"
  productGroup String? // "Группа товара" (напр. "555", "WINKOD + AKIKA"); null для общего плана
  planValue    Float
  unit         String // "EUR" | "LITERS" | "PIECES"
  weightPct    Float

  @@map("plans")
}

model AcbPlan {
  id          Int     @id @default(autoincrement())
  manager     Manager @relation(fields: [managerId], references: [id])
  managerId   Int     @unique
  acbTotal    Int
  acbOil      Int
  weightPct   Float

  @@map("acb_plans")
}

model MissingInvoice {
  id              Int      @id @default(autoincrement())
  client          Client   @relation(fields: [clientId], references: [id])
  clientId        Int
  manager         Manager? @relation(fields: [managerId], references: [id])
  managerId       Int?
  orderRef        String
  deliveryVariant String?

  @@map("missing_invoices")
}

model DataLoad {
  id          Int               @id @default(autoincrement())
  sourceFile  String
  sourceType  String // e.g. "price_list", "discounts", "debt", ...
  loadedAt    DateTime          @default(now())
  rowsTotal   Int
  rowsOk      Int
  rowsError   Int
  status      String // "success" | "partial" | "failed"
  errors      ValidationError[]

  @@map("data_loads")
}

model ValidationError {
  id         Int      @id @default(autoincrement())
  dataLoad   DataLoad @relation(fields: [dataLoadId], references: [id])
  dataLoadId Int
  sheet      String?
  rowNumber  Int?
  field      String?
  message    String
  rawValue   String?

  @@map("validation_errors")
}
