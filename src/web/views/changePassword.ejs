<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
  <title>Смена пароля — Phaeton ТП</title>
  <link rel="stylesheet" href="/styles.css">
  <link rel="manifest" href="/manifest.webmanifest">
</head>
<body>
  <div class="screen">
    <%- include('partials/nav', { user }) %>
    <div class="header">
      <h1>Смена пароля</h1>
    </div>
    <div class="card">
      <% if (error) { %><p class="attention-debt"><%= error %></p><% } %>
      <% if (done) { %><p class="empty-state">Пароль обновлён.</p><% } %>
      <form method="post" action="/account/password" class="form">
        <label class="form-label">Текущий пароль</label>
        <input class="form-input" type="password" name="currentPassword" required>
        <label class="form-label">Новый пароль</label>
        <input class="form-input" type="password" name="newPassword" minlength="6" required>
        <button class="form-button" type="submit">Сохранить</button>
      </form>
    </div>
  </div>
</body>
</html>
