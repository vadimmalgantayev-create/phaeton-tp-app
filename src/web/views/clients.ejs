<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
  <title>Клиенты — Phaeton ТП</title>
  <link rel="stylesheet" href="/styles.css">
  <link rel="manifest" href="/manifest.webmanifest">
</head>
<body>
  <div class="screen">
    <%- include('partials/nav', { user }) %>
    <div class="header">
      <h1>Клиенты</h1>
    </div>

    <% const qParam = q ? `q=${encodeURIComponent(q)}&` : ''; %>
    <% const colorParam = color ? `color=${encodeURIComponent(color)}&` : ''; %>

    <div class="card">
      <form method="get" action="/clients" class="form">
        <input class="form-input" type="text" name="q" placeholder="Поиск: имя, код" value="<%= q || '' %>">
        <% if (color) { %><input type="hidden" name="color" value="<%= color %>"><% } %>
        <button class="form-button" type="submit">Найти</button>
      </form>
      <div class="color-filter" style="margin-top:10px">
        <a class="color-filter-btn<%= !color ? ' active' : '' %>" href="?<%= qParam %>">Все</a>
        <a class="color-filter-btn<%= color === 'green' ? ' active' : '' %>" href="?<%= qParam %>color=green">🟢 Зелёные</a>
        <a class="color-filter-btn<%= color === 'orange' ? ' active' : '' %>" href="?<%= qParam %>color=orange">🟠 Оранжевые</a>
        <a class="color-filter-btn<%= color === 'red' ? ' active' : '' %>" href="?<%= qParam %>color=red">🔴 Красные</a>
      </div>
      <p class="empty-state" style="margin-top:10px">
        План клиента = доля клиента в продажах менеджера (EUR) за последние 4 месяца × общий план менеджера на текущий месяц.
      </p>
    </div>

    <div class="card">
      <p class="empty-state">Найдено: <%= total %> (<%= page %>/<%= totalPages %>)</p>
      <% items.forEach(function(c) { %>
        <a href="/clients/<%= c.id %>" style="text-decoration:none;color:inherit">
          <div class="attention-row client-row-<%= c.color %>">
            <div class="attention-client">
              <%= c.name %>
              <% if (c.managerName) { %><span class="attention-date"><%= c.managerName %></span><% } %>
            </div>
            <div class="attention-debt">
              <% if (c.isOverdue) { %><span class="badge-stub">просрочка</span><% } %>
              <% if (c.hasMissingInvoice) { %><span class="badge-stub">нет накладных</span><% } %>
            </div>
          </div>
          <div class="task-target" style="padding:0 0 10px">
            <span class="client-fact-badge client-fact-<%= c.color %>">факт: <%= Math.round(c.factEur).toLocaleString('ru-RU') %> EUR</span>
            <% if (c.planEur !== null) { %>
              · план: <%= Math.round(c.planEur).toLocaleString('ru-RU') %> EUR
              <% if (c.percent !== null) { %> (<%= c.percent %>%)<% } %>
            <% } else { %>
              · план не рассчитан <span class="badge-stub">нет истории продаж</span>
            <% } %>
          </div>
        </a>
      <% }) %>
    </div>

    <div class="card">
      <div class="nav">
        <% if (page > 1) { %><a href="?<%= qParam %><%= colorParam %>page=<%= page - 1 %>">← назад</a><% } %>
        <% if (page < totalPages) { %><a href="?<%= qParam %><%= colorParam %>page=<%= page + 1 %>">вперёд →</a><% } %>
      </div>
    </div>
  </div>
</body>
</html>
